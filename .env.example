# Copy this to .env and fill in values
# For Vercel: set these as Environment Variables in the dashboard

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=raktchOPS
MONGODB_NAME=raktchops

DJANGO_SECRET_KEY=<generate-a-long-random-string>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<your-backend-vercel-url>.vercel.app,localhost
DJANGO_CORS_ALLOWED_ORIGINS=https://<your-frontend-vercel-url>.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://<your-frontend-vercel-url>.vercel.app

# Email (optional — defaults to console backend)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

FRONTEND_URL=https://<your-frontend-vercel-url>.vercel.app
DJANGO_PASSWORD_RESET_URL=https://<your-frontend-vercel-url>.vercel.app/reset-password
DJANGO_EMAIL_VERIFICATION_URL=https://<your-frontend-vercel-url>.vercel.app/verify-email
